{
  "name": "e2etest29may",
  "version": "1.0.0",
  "description": "Playwright E2E Tests with AI Capabilities incl MCP",
  "main": "index.js",
  "scripts": {
    "dev:make-apt": "npx playwright test --config=config/dev.playwright.config.ts tests/functional/make.aptmnt.spec.ts --headed",
    "test:make-apt": "npx playwright test --config=config/test.playwright.config.ts tests/functional/make.aptmnt.spec.ts --headed",
    "demo:params": "npx playwright test tests/demo/params.make.aptmnt.spec.ts --headed",
    "demo:parallel": "npx playwright test --grep @demo",
    "demo:global": "npx playwright test tests/functional/login.spec.ts",
    "demo:tag": "npx playwright test --grep @smoke --headed",
    "pw-adv-cap": "DEBUG=pw:api npx playwright test tests/demo/pw.adv.cap.login.spec.ts --headed",
    "pw-basic-cap": "npx playwright test tests/demo/pw.basic.cap.make.aptmnt.spec.ts --headed",
    "inventory:trace": "npx playwright test tests/functional/inventory.spec.ts --trace on",
    "inventory:cli": "PWDEBUG=1 npx playwright test tests/functional/inventory.spec.ts",
    "inventory": "npx playwright test tests/functional/inventory.spec.ts --headed",
    "inventory:ui": "npx playwright test tests/functional/inventory.spec.ts --ui --headed",
    "ele-int": "npx playwright test tests/demo/ele.handling.make.aptmnt.spec.ts --headed",
    "make-apt": "npx playwright test tests/functional/make.aptmnt.spec.ts --headed",
    "login": "npx playwright test tests/functional/login.spec.ts --headed",
    "demo": "npx playwright test tests/demo/mytest.spec.ts --headed"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.2",
    "allure-playwright": "^3.9.0",
    "chalk": "^5.6.2",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
